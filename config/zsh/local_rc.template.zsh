# ── 기기/환경별 로컬 설정 템플릿 ─────────────────────────────
# 이 파일을 ~/.config/zsh/local_rc.zsh 로 복사해서 사용하세요
# 절대 dotfiles 레포에 커밋하지 마세요

# ── API 키 ────────────────────────────────────────────────────
# export ANTHROPIC_API_KEY="sk-ant-..."

# ── kubectl 컨텍스트 (회사 PC) ────────────────────────────────
# export CONTEXT=your-k8s-cluster
# export NAMESPACE=your-namespace

# ── AWS ───────────────────────────────────────────────────────
# export AWS_PROFILE=your-profile

# ── 회사 전용 PATH ────────────────────────────────────────────
# export PATH="/opt/company-tools/bin:$PATH"

# ── 기타 환경별 설정 ──────────────────────────────────────────
